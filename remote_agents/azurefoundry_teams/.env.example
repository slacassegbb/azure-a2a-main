# A2A Teams Agent Configuration

# ============================================
# Azure AI Foundry Configuration
# ============================================
# Required: Azure AI Foundry Project Endpoint
# Example: https://your-project.cognitiveservices.azure.com/
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=your-foundry-project-endpoint

# Required: Azure AI Agent Model Deployment Name  
AZURE_AI_AGENT_MODEL_DEPLOYMENT_NAME=gpt-4o

# ============================================
# Microsoft Teams Bot Credentials (Single Tenant)
# ============================================
# Microsoft Teams Bot Credentials (from Azure Bot Registration)
# Get these from Azure Portal > Bot Services > Your Bot > Configuration
MICROSOFT_APP_ID=your-bot-app-id
MICROSOFT_APP_PASSWORD=your-bot-app-password

# Azure AD Tenant ID (required for Single Tenant bots)
# Get this from Azure Portal > Azure Active Directory > Overview
MICROSOFT_APP_TENANT_ID=your-tenant-id

# App Type: SingleTenant or MultiTenant
MICROSOFT_APP_TYPE=SingleTenant

# ============================================
# A2A Configuration
# ============================================
# Hostname or base domain the agent binds to (defaults to localhost)
A2A_ENDPOINT=localhost

# Port for the agent's A2A API (default 8021 for Teams agent)
A2A_PORT=8021

# Host agent URL for self-registration (empty string disables)
A2A_HOST=http://localhost:12000

# ============================================
# Azure Blob Storage (for file uploads from Teams)
# ============================================
# Set to "true" to enable uploading Teams file attachments to Azure Blob Storage
FORCE_AZURE_BLOB="true"

# Azure Storage connection string
AZURE_STORAGE_CONNECTION_STRING=""

# Blob container name (default: a2a-files)
AZURE_BLOB_CONTAINER="a2a-files"

# SAS token validity in minutes (default: 1440 = 24 hours)
AZURE_BLOB_SAS_DURATION_MINUTES=1440

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO